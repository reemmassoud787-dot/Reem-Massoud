    "import os\n",
    "from ultralytics import YOLO\n",
    "\n",
    "# 1. Load the fine-tuned model and set class name to Box\n",
    "model = YOLO(\"/kaggle/working/runs/detect/train/weights/best.pt\")\n",
    "model.model.names[0] = \"Box\"\n",
    "\n",
    "# 2. Define the Safety Threshold for the Warehouse\n",
    "MIN_STOCK_THRESHOLD = 10\n",
    "\n",
    "# 3. Run Inference on Test Images\n",
    "results = model.predict(source=dataset.location + \"/test/images\", imgsz=640, verbose=False)\n",
    "\n",
    "print(\"🔍 Scanning warehouse inventory and verifying quantities...\")\n",
    "print(\"=\" * 60)\n",
    "\n",
    "# These variables will be very useful for your UI Coding later\n",
    "total_boxes_in_warehouse = 0\n",
    "warehouse_status = \"Stable\"  # Default status\n",
    "alert_message = \"\"\n",
    "\n",
    "for i, r in enumerate(results):\n",
    "    boxes_counted = len(r.boxes)\n",
    "    img_name = os.path.basename(r.path)\n",
    "    \n",
    "    total_boxes_in_warehouse += boxes_counted\n",
    "    print(f\"🖼️ Image: {img_name} | Boxes Detected: {boxes_counted}\")\n",
    "\n",
    "print(\"=\" * 60)\n",
    "print(f\"📊 FINAL REPORT - Total Stock in Warehouse: {total_boxes_in_warehouse} Boxes\")\n",
    "\n",
    "# 4. Smart Decision Making Based on Total Stock\n",
    "if total_boxes_in_warehouse < MIN_STOCK_THRESHOLD:\n",
    "    warehouse_status = \"DANGER / LOW STOCK\"\n",
    "    alert_message = f\"ALERT: Warehouse is running low! Current stock ({total_boxes_in_warehouse}) is below the minimum safety threshold ({MIN_STOCK_THRESHOLD}). Reorder immediately!\"\n",
    "    print(f\"🚨 {alert_message}\")\n",
    "else:\n",
    "    warehouse_status = \"STABLE\"\n",
    "    alert_message = \"Warehouse status: Stable and secure. Current stock is sufficient.\"\n",
    "    print(f\"✅ {alert_message}\")\n",
    "print(\"=\" * 60)\n",
    "\n",
    "# 💡 Variables ready to be sent to your UI:\n",
    "# 1. total_boxes_in_warehouse (The final count)\n",
    "# 2. warehouse_status (Either 'STABLE' or 'DANGER / LOW STOCK')\n",
    "# 3. alert_message (The text notification)"
